[[ -r ~/Repos/znap/znap.zsh ]] ||
  git clone --depth 1 -- https://github.com/marlonrichert/zsh-snap.git ~/Repos/znap
source ~/Repos/znap/znap.zsh

# Prevent zsh-autosuggestions widget recursion issues
export FUNCNEST=1000
export ZSH_AUTOSUGGEST_MANUAL_REBIND=1

# Configure znap caching to prevent duplicate loading
zstyle ':znap:*' auto-compile yes

source ~/.bashrc

znap source zsh-users/zsh-syntax-highlighting

# Guard against multiple autosuggestions initializations
if [[ -z "$_ZSH_AUTOSUGGEST_VERSION" ]]; then
  znap source zsh-users/zsh-autosuggestions
fi

znap source ohmyzsh/ohmyzsh plugins/direnv


# source $HOME/.config/broot/launcher/bash/br  # Broken symlink, broot not installed


# necessary - otherwise ssh-agent has to be loaded manually
# zstyle :omz:plugins:ssh-agent identities ~/.ssh/f_github
# znap source ohmyzsh/ohmyzsh plugins/ssh-agent

# https://github.com/marlonrichert/zsh-snap/issues/163
# init starship
# znap eval _starship 'starship init zsh --print-full-init'
# znap prompt starship

znap prompt sindresorhus/pure

# znap eval _pyenv-init "$(pyenv virtualenv-init -)"
# znap eval _direnv-hook "$(direnv hook zsh)"

setopt extended_glob


# alias music_dl="/Users/s1//projects/music/.venv/bin/python $HOME/projects/music/music/download/cli.py" # requires quotes
alias music_process="/Users/s1/projects/music/.venv/bin/python /Users/s1/projects/music/music/process/cli.py" # requires quotes

# Must be present for pyenv to work
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init --path)"
# eval "$(pyenv virtualenv-init -)" # Optional, but good practice if using Venvs


function mkenv() {
    rm -rf ./.venv && \
    python -m venv ./.venv && \
    . ./.venv/bin/activate && \
    python -m ensurepip --upgrade && \
    pip install --upgrade setuptools
}


# These 4 commands are required to map the behaviour on OSX (untested on linux)
# Home, End to jump to beginning and end of line
bindkey "\e[H" beginning-of-line
bindkey "\e[F" end-of-line
# Ctrl_Left, Ctrl-Right to go back and forward a word
bindkey "\e[1;5D" backward-word
bindkey "\e[1;5C" forward-word

# I don't care for this feature, and it causes the terminal to change the background color
unset zle_bracketed_paste


# ~/.local/bin is not on $PATH on OSX or Linux (OpenSUSE, Debian, Ubuntu)
# in rare cases, ~/.local/bin is used as a copy destination for manually compiled apps
# some rust and haskell apps I've used compile and copy the binary to this location
# Therefore, add custom script directory from the repo onto Path
# Instead of symlinking REPO/bin -> $HOME/.local/bin
export PATH="$PATH:$HOME/dot/bin/src"

export ANTHROPIC_BASE_URL="http://localhost:8000"
# otherwise claude keeps asking you to login
export ANTHROPIC_API_KEY="sk-local-token"
export ANTHROPIC_MODEL="Qwen3.5-122B-A10B-8bit"
# Set the Architect (The Smart One)
export ANTHROPIC_DEFAULT_OPUS_MODEL="Qwen3.5-122B-A10B-8bit"
# Set the Brain (The Fast One)
 
export ANTHROPIC_DEFAULT_SONNET_MODEL="Qwen3-14B-8bit"
# Set the Scout (Also the Fast One)
export ANTHROPIC_DEFAULT_HAIKU_MODEL="Qwen3-14B-8bit"


# . "$HOME/.local/share/../bin/env"

# alias music_dl="/Users/s1//projects/music/.venv/bin/python $HOME/projects/music/music/download/cli.py" # requires quotes
alias music_process="/Users/s1/projects/music/.venv/bin/python /Users/s1/projects/music/music/process/cli.py" # requires quotes


# 1. Define the PYENV_ROOT variable (where pyenv is installed)
export PYENV_ROOT="$HOME/.pyenv"
command -v pyenv >/dev/null || export PATH="$PYENV_ROOT/bin:$PATH"
# 3. Initialize pyenv's shims
eval "$(pyenv init -)"

# opencode
export PATH=/Users/s1/.opencode/bin:$PATH

if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init zsh)"; fi
eval "$(tv init zsh)"

. "$HOME/.atuin/bin/env"

eval "$(atuin init zsh)"
